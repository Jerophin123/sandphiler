# Server configuration
PORT=5000
NODE_ENV=production

# Sandboxing configuration
# For Linux/Ubuntu production: /sandbox
# For Windows local dev testing: ./sandbox (will create folder locally)
SANDBOX_ROOT=/sandbox

# Execute commands using sudo? Set to true on Ubuntu production
USE_SUDO=true
SANDBOX_USER=sandbox

# Queue and Worker Configuration
MAX_CONCURRENT_EXECUTIONS=10
QUEUE_TIMEOUT_MS=30000

# Cleanup configuration (intervals in milliseconds)
CLEANUP_INTERVAL_MS=60000
STALE_THRESHOLD_MS=300000

# Default execution profile (competitive-programming, high-memory, quick-execution, interactive-terminal, restricted-mode)
DEFAULT_PROFILE=interactive-terminal

# Remote VM routing (future distributed scaling)
REMOTE_VM_ENABLED=false
REMOTE_VM_POOL=http://10.0.0.10:5000,http://10.0.0.11:5000
